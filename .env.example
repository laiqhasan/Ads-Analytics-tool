# Database URL
DATABASE_URL=postgresql://user:password@localhost:5432/ads_analytics

# Gemini API Key (for narrative summaries and agentic deep dives)
GEMINI_API_KEY=your_gemini_api_key_here

# ==========================================
# Google Ads API Setup
# ==========================================
# Manager Account (MCC) developer token
GOOGLE_DEVELOPER_TOKEN=your_developer_token_here
# Client credentials (generated in Google Cloud project)
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
# Refresh token generated through OAuth consent flow
GOOGLE_REFRESH_TOKEN=your_refresh_token_here
# Your MCC Manager Customer ID (without dashes)
GOOGLE_LOGIN_CUSTOMER_ID=your_mcc_id_here

# ==========================================
# Meta Ads API Setup
# ==========================================
# Meta System User / Access Token with ads_read permissions
META_ACCESS_TOKEN=your_meta_access_token_here
# Comma-separated list of target Meta Ad Account IDs, e.g. act_1234567,act_7654321
META_AD_ACCOUNT_IDS=act_your_account_id_here
